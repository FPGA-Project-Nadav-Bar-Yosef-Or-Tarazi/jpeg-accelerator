/*
 * Avalon-MM register access.
 *
 * From Nios II C code, offsets are byte offsets.
 * Therefore register number n is accessed as offset 4*n.
 */
#define DCT_RD(op)          IORD_32DIRECT(DCT_ACCEL_BASE, 4 * (op))
#define DCT_WR(op, data)    IOWR_32DIRECT(DCT_ACCEL_BASE, 4 * (op), (data))

