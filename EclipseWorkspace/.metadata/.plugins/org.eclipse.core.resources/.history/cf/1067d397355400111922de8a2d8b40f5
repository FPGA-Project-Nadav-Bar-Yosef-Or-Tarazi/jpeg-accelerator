    {0.4157348061512726, -0.0975451610080641, -0.4903926402016152, -0.2777851165098011,  0.2777851165098009,  0.4903926402016153,  0.0975451610080644, -0.4157348061512721},
    {0.3535533905932738, -0.3535533905932737, -0.3535533905932738,  0.3535533905932737,  0.3535533905932738, -0.3535533905932733, -0.3535533905932736,  0.3535533905932733},
