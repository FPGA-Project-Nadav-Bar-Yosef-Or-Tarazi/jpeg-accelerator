/*
 * jpeg_encoder_no_dpcm.c
 *
 * Standalone C version of the provided MATLAB imageEncoder_noDPCM.m
 * Target: embedded / FPGA soft-core environment
 *
 * No malloc, no printf, no file I/O, no math library calls.
 * The output bitstream is written into a caller-provided char buffer.
 *
 * IMPORTANT:
 * The MATLAB code calls golomb_enc(), but its implementation was not provided.
 * This file includes a simple signed Exp-Golomb style encoder as a placeholder.
 * Replace golomb_enc_symbol() if your MATLAB golomb_enc() uses a different code.
 */

#include <stdio.h>
#define IMG_W 64
#define IMG_H 64
#define BLOCK_SIZE 8
#define BLOCKS_X 8
#define BLOCKS_Y 8
#define N_BLOCKS 64
#define DCT_N 8

/** Cosine transform matrix compatible with MATLAB-style orthonormal DCT-II.
 * C[u][x] = alpha(u) * cos(pi * (2*x+1) * u / 16)
 * alpha(0)=sqrt(1/8), alpha(u)=sqrt(2/8) for u>0
 */
