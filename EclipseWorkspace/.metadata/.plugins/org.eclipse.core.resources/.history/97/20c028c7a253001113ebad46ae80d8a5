/*
 * jpeg_encoder_no_dpcm.c
 *
 * Final corrected version:
 * - Correct MATLAB-compatible zigzag
 * - Correct block traversal order
 * - Correct column-major flattening
 * - Generates MATLAB .m file
 */

#include <stdio.h>
#include "sky_image.h"

#define IMG_W 800
#define IMG_H 800

#define BLOCK_SIZE 8
#define BLOCKS_X 100
#define BLOCKS_Y 100
#define N_BLOCKS 10000

static const double DCT_C[8][8] = {
    {0.3535533905932738,0.3535533905932738,0.3535533905932738,0.3535533905932738,0.3535533905932738,0.3535533905932738,0.3535533905932738,0.3535533905932738},
